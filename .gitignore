# Build outputs (regenerated by CI)
build/

# Raw PDF extraction dumps (derivable from extract.py; bulky)
src/raw/

# OS / editor noise
.DS_Store
*.swp

# Lab runtime
lab/**/*.log

# TLS keys (generate locally with lab/make-certs.sh)
lab/asterisk/etc/keys/

# DOCX media working cache (regenerate via pandoc --extract-media; final images go in src/images/)
src/docx-media/

# Trashcan — retired files kept locally, out of the repo
.trash/

# Secrets — never commit
.env
.env.*
!.env.example

# Provider production config (reference only — contains third-party secrets/numbers)
/sip.conf
/extensions.conf

# Slidev
slides/node_modules/
slides/dist*/
slides/.slidev/
.claude/scheduled_tasks.lock
